  m_Script: {fileID: 11500000, guid: f1f07152f70b41b5819372d0008d5eea, type: 3}
  m_Name: DeathMessagesData
  m_EditorClassIdentifier: Assembly-CSharp::DeathMessagesData
  titleEN: YOU DIED
  messagesEN:
  - The castle claims another soul...
  - Your body crumbles, but your will remains.
  - "Death is not the end \u2014 it is a doorway."
  - The spirit of war feasts on your failure.
  - You fought well, but the castle fights better.
  - Another body lost to the ancient halls.
  - The entity watches. It always watches.
  - Your soul slips through its grasp once more.
  - The basement awaits its newest vessel.
  - "Try and try again \u2014 the castle demands it."
  hintEN: '[ENTER] Find a new vessel

    [ESC] Abandon the castle'
  titleRU: "\u0412\u042B \u041F\u041E\u0413\u0418\u0411\u041B\u0418"
  messagesRU:
  - "\u0417\u0430\u043C\u043E\u043A \u0437\u0430\u0431\u0438\u0440\u0430\u0435\u0442
    \u0435\u0449\u0451 \u043E\u0434\u043D\u0443 \u0434\u0443\u0448\u0443..."
  - "\u0422\u0432\u043E\u0451 \u0442\u0435\u043B\u043E \u0440\u0430\u0441\u0441\u044B\u043F\u0430\u0435\u0442\u0441\u044F,
    \u043D\u043E \u0432\u043E\u043B\u044F \u043E\u0441\u0442\u0430\u0451\u0442\u0441\u044F."
  - "\u0421\u043C\u0435\u0440\u0442\u044C \u2014 \u044D\u0442\u043E \u043D\u0435
    \u043A\u043E\u043D\u0435\u0446, \u044D\u0442\u043E \u0432\u0440\u0430\u0442\u0430."
  - "\u0414\u0443\u0445 \u0432\u043E\u0439\u043D\u044B \u043F\u0438\u0440\u0443\u0435\u0442
    \u043D\u0430 \u0442\u0432\u043E\u0438\u0445 \u043D\u0435\u0443\u0434\u0430\u0447\u0430\u0445."
  - "\u0422\u044B \u0441\u0440\u0430\u0436\u0430\u043B\u0441\u044F \u0445\u0440\u0430\u0431\u0440\u043E,
    \u043D\u043E \u0437\u0430\u043C\u043E\u043A \u0441\u0440\u0430\u0436\u0430\u0435\u0442\u0441\u044F
    \u043B\u0443\u0447\u0448\u0435."
  - "\u041E\u0447\u0435\u0440\u0435\u0434\u043D\u043E\u0435 \u0442\u0435\u043B\u043E
    \u043F\u043E\u0442\u0435\u0440\u044F\u043D\u043E \u0432 \u0434\u0440\u0435\u0432\u043D\u0438\u0445
    \u0437\u0430\u043B\u0430\u0445."
  - "\u0421\u0443\u0449\u043D\u043E\u0441\u0442\u044C \u043D\u0430\u0431\u043B\u044E\u0434\u0430\u0435\u0442.
    \u041E\u043D\u0430 \u0432\u0441\u0435\u0433\u0434\u0430 \u043D\u0430\u0431\u043B\u044E\u0434\u0430\u0435\u0442."
  - "\u0422\u0432\u043E\u044F \u0434\u0443\u0448\u0430 \u0441\u043D\u043E\u0432\u0430
    \u0443\u0441\u043A\u043E\u043B\u044C\u0437\u0430\u0435\u0442 \u043E\u0442 \u0435\u0451
    \u0445\u0432\u0430\u0442\u043A\u0438."
  - "\u041F\u043E\u0434\u0432\u0430\u043B \u0436\u0434\u0451\u0442 \u0441\u0432\u043E\u0451
    \u043D\u043E\u0432\u043E\u0435 \u0432\u043C\u0435\u0441\u0442\u0438\u043B\u0438\u0449\u0435."
  - "\u041F\u044B\u0442\u0430\u0439\u0441\u044F \u0441\u043D\u043E\u0432\u0430 \u0438
    \u0441\u043D\u043E\u0432\u0430 \u2014 \u0437\u0430\u043C\u043E\u043A \u0442\u0440\u0435\u0431\u0443\u0435\u0442
    \u044D\u0442\u043E\u0433\u043E."
  hintRU: "[ENTER] \u041D\u0430\u0439\u0442\u0438 \u043D\u043E\u0432\u044B\u0439
    \u0441\u043E\u0441\u0443\u0434\n[ESC] \u041F\u043E\u043A\u0438\u043D\u0443\u0442\u044C
    \u0437\u0430\u043C\u043E\u043A"
